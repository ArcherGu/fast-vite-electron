{
  "name": "fast-vite-electron",
  "version": "0.0.1",
  "packageManager": "pnpm@11.5.0",
  "description": "Vite + Electron with esbuild, so fast! ⚡",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "rimraf dist && vite",
    "debug": "rimraf dist && vite -- --dsb-debug",
    "build": "rimraf dist && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:main && npm run test:render",
    "test:render": "vitest run -r src/render --passWithNoTests",
    "test:main": "vitest run -r src/main --passWithNoTests",
    "test:e2e": "vitest run",
    "postinstall": "npx simple-git-hooks && electron-builder install-app-deps"
  },
  "dependencies": {
    "einf": "^1.7.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "1.0.155",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/compiler-sfc": "3.5.35",
    "@vue/test-utils": "2.4.11",
    "baseline-browser-mapping": "^2.10.33",
    "electron": "42.3.3",
    "electron-builder": "26.8.1",
    "eslint": "10.4.1",
    "happy-dom": "20.10.1",
    "lint-staged": "17.0.7",
    "playwright": "1.60.0",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-doubleshot": "0.0.23",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
